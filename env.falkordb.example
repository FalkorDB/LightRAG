# Example .env configuration for FalkorDB
# Add these environment variables to use FalkorDB as your graph storage

# Graph storage type
LIGHTRAG_GRAPH_STORAGE=FalkorDBStorage

# FalkorDB connection settings
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
# FALKORDB_PASSWORD=your_password_if_required
# FALKORDB_USERNAME=your_username_if_required

# Graph name (will be created if doesn't exist)
FALKORDB_GRAPH_NAME=lightrag_graph

# Optional: Workspace for multi-tenant usage
# FALKORDB_WORKSPACE=my_workspace

# You can also use a config.ini file instead of environment variables:
# [falkordb]
# host = localhost
# port = 6379
# password = your_password
# username = your_username
# graph_name = lightrag_graph